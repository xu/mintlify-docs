        "requestBody": {
          "description": "更新信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/internal_api.UpdateApiKeyRequest"
              }
            }
          }
        }
      }
    },
    "/api/v1/asset/transfer": {
      "post": {
        "summary": "创建资金划转",
        "description": "在用户的账户内进行业务单元间的资金划转。",
