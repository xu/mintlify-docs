              }
            }
          }
        }
      }
    },
    "/inner/auth/verify-signature": {
      "post": {
        "summary": "内部签名校验",
        "description": "验证 OpenAPI 请求的 HMAC-SHA256 签名。",
        "tags": [
          "内部接口"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifySignatureResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "签名信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifySignatureRequest"
              }
            }
          }
        }
      }
    },
    "/inner/auth/verify-token": {
