              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/phx-broker-gateway_internal_model.ApiKeyListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/apikey/update": {
      "post": {
        "summary": "更新用户 API Key",
        "description": "更新访问密钥的权限、IP 白名单或状态。",
        "tags": [
          "密钥管理"
        ],
        "parameters": [
          {
            "type": "string",
            "description": "券商 API Key",
