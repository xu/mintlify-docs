                        "name": "x-timestamp",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "签名结果",
                        "name": "x-signature",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "登出信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_api.LogoutUserRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.Response"
                        }
                    }
                }
            }
        },
        "/api/v1/user/register": {
            "post": {
                "description": "将券商侧用户 ID 映射到平台全局 UID。如果用户已存在，返回现有 UID。",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "用户管理"
                ],
                "summary": "用户注册",
                "parameters": [
                    {
                        "type": "string",
                        "description": "券商 API Key",
                        "name": "x-api-key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "时间戳",
                        "name": "x-timestamp",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "签名结果",
                        "name": "x-signature",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "注册信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
