{
    "swagger": "2.0",
    "info": {
        "description": "券商管理与用户映射服务接口文档",
        "title": "PHX Broker Gateway 接口文档",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:38008",
    "basePath": "/",
    "paths": {
        "/api/v1/apikey/create": {
            "post": {
                "description": "为特定用户创建新的访问密钥对。",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "密钥管理"
                ],
                "summary": "创建用户 API Key",
                "parameters": [
                    {
                        "type": "string",
                        "description": "券商 API Key",
                        "name": "x-api-key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "签名结果",
                        "name": "x-signature",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "创建信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_api.CreateApiKeyRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.ApiKeyCreateResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/apikey/delete": {
            "post": {
                "description": "永久删除指定的访问密钥。",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "密钥管理"
                ],
                "summary": "删除用户 API Key",
                "parameters": [
                    {
                        "type": "string",
                        "description": "券商 API Key",
                        "name": "x-api-key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "签名结果",
                        "name": "x-signature",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "删除信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_api.DeleteApiKeyRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.Response"
                        }
                    }
                }
            }
        },
        "/api/v1/apikey/list": {
            "get": {
                "description": "获取指定用户下的所有访问密钥。",
