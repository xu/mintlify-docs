        "/inner/user/create-special": {
            "post": {
                "description": "创建系统账户或做市商账户，UID 遵循特定范围且不混淆。",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "内部接口"
                ],
                "summary": "创建特殊账户 (系统/做市商)",
                "parameters": [
                    {
                        "description": "账户信息",
                        "name": "request",
                        "in": "body",
