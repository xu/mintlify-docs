        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/phx-broker-gateway_internal_model.Response"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "划转信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/internal_api.TransferRequest"
              }
            }
          }
        }
      }
    },
