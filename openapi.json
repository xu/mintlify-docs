                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "用户管理"
                ],
                "summary": "更新用户信息",
                "parameters": [
                    {
                        "type": "string",
                        "description": "券商 API Key",
                        "name": "x-api-key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "时间戳",
                        "name": "x-timestamp",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "签名结果",
                        "name": "x-signature",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "更新信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_api.UpdateUserRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.Response"
                        }
                    }
                }
            }
        },
        "/inner/auth/verify-signature": {
            "post": {
                "description": "验证 OpenAPI 请求的 HMAC-SHA256 签名。",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "内部接口"
                ],
                "summary": "内部签名校验",
                "parameters": [
                    {
                        "description": "签名信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.VerifySignatureRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.VerifySignatureResponse"
                        }
                    }
                }
            }
        },
        "/inner/auth/verify-token": {
            "post": {
                "description": "校验 Token 合法性并返回简要用户信息。",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "内部接口"
                ],
                "summary": "内部 Token 校验",
                "parameters": [
                    {
                        "description": "Token 信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.VerifyTokenRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.VerifyTokenResponse"
                        }
                    }
                }
            }
        },
        "/inner/broker/all": {
            "get": {
                "description": "获取所有注册券商的简要列表 (ID 和名称)。",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "券商管理"
                ],
                "summary": "获取全部券商列表",
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.BrokerAllResponse"
                        }
                    }
                }
            }
        },
        "/inner/broker/list": {
            "get": {
                "description": "获取所有注册券商的分页列表。",
                "consumes": [
