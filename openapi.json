    "definitions": {
        "internal_api.CreateApiKeyRequest": {
            "type": "object",
            "required": [
                "user_id"
            ],
            "properties": {
                "authorities": {
                    "description": "权限列表 ([READ, TRADE])",
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "[\"READ\"]"
                    ]
                },
                "ip_list": {
                    "description": "IP 白名单 (逗号分隔)",
                    "type": "string",
                    "example": "127.0.0.1"
                },
                "remark": {
                    "description": "备注信息",
                    "type": "string",
                    "example": "我的密钥"
                },
                "user_id": {
                    "description": "券商侧用户 ID",
                    "type": "string",
                    "example": "user_01"
                }
            }
        },
        "internal_api.CreateSpecialUserRequest": {
            "type": "object",
            "required": [
                "broker_id",
                "type"
            ],
            "properties": {
                "broker_id": {
                    "description": "券商 ID",
                    "type": "integer",
                    "example": 1001
                },
                "type": {
                    "description": "账户类型: sys, mm",
                    "type": "string",
                    "enum": [
                        "sys",
                        "mm"
                    ],
                    "example": "sys"
                }
            }
        },
        "internal_api.DeleteApiKeyRequest": {
            "type": "object",
            "required": [
                "api_key"
            ],
            "properties": {
                "api_key": {
                    "description": "待删除的 API Key",
                    "type": "string",
                    "example": "ak_123"
                }
            }
        },
        "internal_api.LoginUserRequest": {
            "type": "object",
            "required": [
                "token",
                "user_id"
            ],
            "properties": {
                "token": {
                    "description": "登录 Token",
                    "type": "string",
                    "example": "token_123"
                },
                "user_id": {
                    "description": "券商侧用户 ID",
                    "type": "string",
                    "example": "user_01"
                }
            }
        },
        "internal_api.LogoutUserRequest": {
            "type": "object",
            "required": [
                "user_id"
            ],
            "properties": {
                "user_id": {
                    "description": "券商侧用户 ID",
                    "type": "string",
                    "example": "user_01"
                }
            }
        },
        "internal_api.RegisterUserRequest": {
            "type": "object",
            "required": [
                "user_id"
            ],
            "properties": {
                "desc": {
                    "description": "用户描述",
                    "type": "string",
                    "example": "测试用户"
                },
                "user_id": {
                    "description": "券商侧用户唯一 ID",
                    "type": "string",
                    "example": "user_01"
                },
                "user_name": {
                    "description": "用户昵称",
                    "type": "string",
                    "example": "张三"
                }
            }
        },
        "internal_api.TransferRequest": {
            "type": "object",
            "required": [
                "amount",
                "currency",
                "direction",
                "txn_id",
                "user_id"
            ],
            "properties": {
                "amount": {
                    "description": "划转金额",
                    "type": "string",
                    "example": "100.00"
                },
                "currency": {
                    "description": "币种",
                    "type": "string",
                    "example": "USDT"
                },
                "direction": {
                    "description": "划转方向: 1-入, 2-出",
                    "type": "integer",
                    "enum": [
                        1,
                        2
                    ],
                    "example": 1
                },
                "remark": {
                    "description": "备注",
                    "type": "string",
                    "example": "充值"
                },
                "txn_id": {
                    "description": "券商侧唯一交易流水号",
                    "type": "string",
                    "example": "txn_123456"
                },
                "user_id": {
                    "description": "券商侧用户 ID",
                    "type": "string",
                    "example": "user_01"
                }
            }
        },
        "internal_api.UpdateApiKeyRequest": {
            "type": "object",
            "required": [
                "api_key"
            ],
            "properties": {
                "api_key": {
                    "description": "待更新的 API Key",
                    "type": "string",
                    "example": "ak_123"
                },
                "authorities": {
                    "description": "权限列表",
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "[\"READ\"]"
                    ]
                },
                "ip_list": {
                    "description": "IP 白名单",
                    "type": "string",
                    "example": "127.0.0.1"
                },
                "remark": {
                    "description": "备注",
                    "type": "string",
                    "example": "更新后的备注"
                },
                "status": {
                    "description": "状态: 1-正常, 2-禁用",
                    "type": "integer",
                    "example": 1
                }
            }
        },
        "internal_api.UpdateUserRequest": {
            "type": "object",
            "required": [
                "user_id"
            ],
            "properties": {
                "desc": {
                    "description": "新描述",
                    "type": "string",
                    "example": "新描述"
                },
                "user_id": {
                    "description": "券商侧用户 ID",
                    "type": "string",
                    "example": "user_01"
                },
                "user_name": {
                    "description": "新昵称",
                    "type": "string",
                    "example": "新昵称"
                }
            }
        },
        "phx-broker-gateway_internal_model.ApiKeyCreateResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 200
                },
                "data": {
                    "$ref": "#/definitions/phx-broker-gateway_internal_model.ApiKeyCreateResponseData"
                },
                "message": {
                    "type": "string",
                    "example": "成功"
                }
            }
        },
        "phx-broker-gateway_internal_model.ApiKeyCreateResponseData": {
            "type": "object",
            "properties": {
                "key": {
                    "description": "API Key 详细信息",
                    "allOf": [
                        {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.BrokerUserApiKey"
                        }
                    ]
                },
                "sk": {
                    "description": "原始 API Secret (仅创建时返回一次)",
                    "type": "string",
                    "example": "abc123456789"
                }
            }
        },
        "phx-broker-gateway_internal_model.ApiKeyListResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 200
                },
                "data": {
