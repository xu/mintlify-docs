{
  "openapi": "3.0.0",
  "info": {
    "description": "券商管理与用户映射服务接口文档",
    "title": "Dcore 接口文档",
    "contact": {},
    "version": "1.0"
  },
  "servers": [
    {
      "url": "http://10.10.1.10:38008",
      "description": "测试环境"
    }
  ],
  "paths": {
    "/api/v1/apikey/create": {
      "post": {
        "summary": "创建用户 API Key",
        "description": "为特定用户创建新的访问密钥对。",
        "tags": [
          "密钥管理"
        ],
        "parameters": [
          {
            "description": "券商 API Key",
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "签名结果",
            "name": "x-signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKeyCreateResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "创建信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateApiKeyRequest"
              }
            }
          }
        }
      }
    },
    "/api/v1/apikey/delete": {
      "post": {
        "summary": "删除用户 API Key",
        "description": "永久删除指定的访问密钥。",
        "tags": [
          "密钥管理"
        ],
        "parameters": [
          {
            "description": "券商 API Key",
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "签名结果",
            "name": "x-signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Response"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "删除信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeleteApiKeyRequest"
              }
            }
          }
        }
      }
    },
    "/api/v1/apikey/list": {
      "get": {
        "summary": "获取 API Key 列表",
        "description": "获取指定用户下的所有访问密钥。",
        "tags": [
          "密钥管理"
        ],
        "parameters": [
          {
            "description": "用户 ID",
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKeyListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/apikey/update": {
      "post": {
        "summary": "更新用户 API Key",
        "description": "更新访问密钥的权限、IP 白名单或状态。",
        "tags": [
          "密钥管理"
        ],
        "parameters": [
          {
            "description": "券商 API Key",
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "签名结果",
            "name": "x-signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Response"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "更新信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateApiKeyRequest"
              }
            }
          }
        }
      }
    },
    "/api/v1/asset/balance": {
      "get": {
        "summary": "查询用户资产余额",
        "description": "查询指定用户在平台上的实时资产余额列表。",
        "tags": [
          "资产管理"
        ],
        "parameters": [
          {
            "description": "券商 API Key",
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "时间戳",
            "name": "x-timestamp",
            "in": "header",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "签名",
            "name": "x-signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "description": "券商侧用户 ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "currency",
            "in": "query",
            "required": false,
            "description": "币种 (可选，不传返回全部)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetBalanceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/asset/transfer": {
      "post": {
        "summary": "创建资金划转",
        "description": "在用户的账户内进行业务单元间的资金划转。",
        "tags": [
          "资产管理"
        ],
        "parameters": [
          {
            "description": "券商 API Key",
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "时间戳",
            "name": "x-timestamp",
            "in": "header",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "签名",
            "name": "x-signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Response"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "划转信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferRequest"
              }
            }
          }
        }
      }
    },
    "/api/v1/user/login": {
      "post": {
        "summary": "用户登录",
