              }
            }
          }
        }
      }
    },
    "/api/v1/user/register": {
      "post": {
        "summary": "用户注册",
        "description": "将券商侧用户 ID 映射到平台全局 UID。如果用户已存在，返回现有 UID。",
        "tags": [
          "用户管理"
        ],
        "parameters": [
          {
            "description": "券商 API Key",
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "时间戳",
            "name": "x-timestamp",
            "in": "header",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "签名结果",
            "name": "x-signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserRegisterResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "注册信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterUserRequest"
              }
            }
          }
        }
      }
    },
