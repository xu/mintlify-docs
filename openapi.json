  "paths": {
    "/api/v1/apikey/create": {
      "post": {
        "summary": "创建用户 API Key",
        "description": "为特定用户创建新的访问密钥对。",
        "tags": [
          "密钥管理"
        ],
        "parameters": [
          {
            "type": "string",
            "description": "券商 API Key",
            "name": "x-api-key",
            "in": "header",
            "required": true
          },
          {
            "type": "string",
            "description": "签名结果",
            "name": "x-signature",
            "in": "header",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/phx-broker-gateway_internal_model.ApiKeyCreateResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "创建信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/internal_api.CreateApiKeyRequest"
              }
            }
          }
        }
      }
    },
    "/api/v1/apikey/delete": {
      "post": {
        "summary": "删除用户 API Key",
        "description": "永久删除指定的访问密钥。",
        "tags": [
          "密钥管理"
        ],
        "parameters": [
          {
            "type": "string",
            "description": "券商 API Key",
            "name": "x-api-key",
            "in": "header",
            "required": true
          },
          {
            "type": "string",
            "description": "签名结果",
            "name": "x-signature",
            "in": "header",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/phx-broker-gateway_internal_model.Response"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "删除信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/internal_api.DeleteApiKeyRequest"
              }
            }
          }
        }
      }
    },
    "/api/v1/apikey/list": {
      "get": {
        "summary": "获取 API Key 列表",
        "description": "获取指定用户下的所有访问密钥。",
