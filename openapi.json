                        "name": "x-api-key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "时间戳",
                        "name": "x-timestamp",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "签名",
                        "name": "x-signature",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "划转信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_api.TransferRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.Response"
                        }
                    }
                }
            }
        },
        "/api/v1/user/login": {
