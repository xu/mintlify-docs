          "内部接口"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyTokenResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "Token 信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyTokenRequest"
              }
            }
          }
        }
      }
    },
    "/inner/broker/all": {
      "get": {
        "summary": "获取全部券商列表",
        "description": "获取所有注册券商的简要列表 (ID 和名称)。",
        "tags": [
          "券商管理"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrokerAllResponse"
                }
              }
            }
          }
        }
      }
    },
    "/inner/broker/list": {
      "get": {
        "summary": "分页获取券商列表",
        "description": "获取所有注册券商的分页列表。",
        "tags": [
          "券商管理"
        ],
        "parameters": [
          {
            "description": "页码",
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "每页数量",
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrokerListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/inner/broker/{broker_id}": {
      "get": {
        "summary": "获取券商详情",
        "description": "根据 ID 获取券商详细信息。",
        "tags": [
          "券商管理"
        ],
        "parameters": [
          {
            "description": "券商 ID",
            "name": "broker_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrokerInfoResponse"
                }
              }
            }
          }
        }
      }
    },
    "/inner/user/create-special": {
      "post": {
        "summary": "创建特殊账户 (系统/做市商)",
        "description": "创建系统账户或做市商账户，UID 遵循特定范围且不混淆。",
        "tags": [
          "内部接口"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserRegisterResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "账户信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSpecialUserRequest"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AssetBalanceRequest": {
        "type": "object",
        "required": [
          "user_id"
        ],
        "properties": {
          "currency": {
            "description": "币种 (可选，不传返回全部)",
            "type": "string",
            "example": "USDT"
          },
          "user_id": {
            "description": "券商侧用户 ID",
            "type": "string",
            "example": "user_01"
          }
        }
      },
      "AssetBalanceResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AssetBalanceItem"
            }
          },
          "message": {
            "type": "string",
            "example": "成功"
          }
        }
      },
      "AssetBalanceItem": {
        "type": "object",
        "properties": {
          "available": {
            "description": "可用余额",
            "type": "string",
            "example": "800.00"
          },
          "balance": {
            "description": "总余额",
            "type": "string",
            "example": "1000.50"
          },
          "currency": {
            "description": "币种",
            "type": "string",
            "example": "USDT"
          },
          "equity": {
            "description": "账户权益",
            "type": "string",
            "example": "1000.50"
          },
          "frozen": {
            "description": "冻结金额",
            "type": "string",
            "example": "200.50"
          }
        }
      },
      "CreateApiKeyRequest": {
        "type": "object",
        "required": [
          "user_id"
        ],
        "properties": {
          "authorities": {
            "description": "权限列表 ([READ, TRADE])",
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "[\"READ\"]"
            ]
          },
          "ip_list": {
            "description": "IP 白名单 (逗号分隔)",
            "type": "string",
            "example": "127.0.0.1"
          },
          "remark": {
            "description": "备注信息",
            "type": "string",
            "example": "我的密钥"
          },
          "user_id": {
            "description": "券商侧用户 ID",
            "type": "string",
            "example": "user_01"
          }
        }
      },
      "CreateSpecialUserRequest": {
        "type": "object",
        "required": [
          "broker_id",
          "type"
        ],
        "properties": {
          "broker_id": {
            "description": "券商 ID",
            "type": "integer",
            "example": 1001
          },
          "type": {
            "description": "账户类型: sys, mm",
            "type": "string",
            "enum": [
              "sys",
              "mm"
            ],
            "example": "sys"
          }
        }
      },
      "DeleteApiKeyRequest": {
        "type": "object",
        "required": [
          "api_key"
        ],
        "properties": {
          "api_key": {
            "description": "待删除的 API Key",
            "type": "string",
            "example": "ak_123"
          }
        }
      },
      "LoginUserRequest": {
        "type": "object",
        "required": [
          "token",
          "user_id"
        ],
        "properties": {
          "token": {
            "description": "登录 Token",
            "type": "string",
            "example": "token_123"
          },
          "user_id": {
            "description": "券商侧用户 ID",
            "type": "string",
            "example": "user_01"
          }
        }
      },
      "LogoutUserRequest": {
        "type": "object",
        "required": [
          "user_id"
        ],
        "properties": {
          "user_id": {
            "description": "券商侧用户 ID",
            "type": "string",
            "example": "user_01"
          }
        }
      },
      "RegisterUserRequest": {
        "type": "object",
        "required": [
          "user_id"
        ],
        "properties": {
          "desc": {
            "description": "用户描述",
            "type": "string",
            "example": "测试用户"
          },
          "user_id": {
            "description": "券商侧用户唯一 ID",
            "type": "string",
            "example": "user_01"
          },
          "user_name": {
            "description": "用户昵称",
            "type": "string",
            "example": "张三"
          }
        }
      },
      "TransferRequest": {
        "type": "object",
        "required": [
          "amount",
          "currency",
          "direction",
          "txn_id",
          "user_id"
        ],
        "properties": {
          "amount": {
            "description": "划转金额",
            "type": "string",
            "example": "100.00"
          },
          "currency": {
            "description": "币种",
            "type": "string",
            "example": "USDT"
          },
          "direction": {
            "description": "划转方向: 1-入, 2-出",
            "type": "integer",
            "enum": [
              1,
              2
            ],
            "example": 1
          },
          "remark": {
            "description": "备注",
            "type": "string",
            "example": "充值"
          },
          "txn_id": {
            "description": "券商侧唯一交易流水号",
            "type": "string",
