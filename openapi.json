                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.ApiKeyListResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/apikey/update": {
            "post": {
                "description": "更新访问密钥的权限、IP 白名单或状态。",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "密钥管理"
                ],
                "summary": "更新用户 API Key",
                "parameters": [
                    {
                        "type": "string",
                        "description": "券商 API Key",
                        "name": "x-api-key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "签名结果",
                        "name": "x-signature",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "更新信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_api.UpdateApiKeyRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/phx-broker-gateway_internal_model.Response"
                        }
                    }
                }
            }
        },
        "/api/v1/asset/transfer": {
            "post": {
                "description": "在用户的账户内进行业务单元间的资金划转。",
                "consumes": [
                    "application/json"
                ],
                "produces": [
