        "parameters": [
          {
            "type": "string",
            "description": "券商 API Key",
            "name": "x-api-key",
            "in": "header",
            "required": true
          },
          {
            "type": "integer",
            "description": "时间戳",
            "name": "x-timestamp",
            "in": "header",
            "required": true
          },
          {
            "type": "string",
            "description": "签名",
            "name": "x-signature",
            "in": "header",
            "required": true
          }
