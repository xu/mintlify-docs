{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PHX Broker Gateway",
  "colors": {
    "primary": "#0070f3",
    "light": "#3291ff",
    "dark": "#003159"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "入门指南",
        "groups": [
          {
            "group": "入门指南",
            "pages": [
              "guide/introduction",
              "guide/authentication",
              "guide/response"
            ]
          }
        ]
      },
      {
        "tab": "API 参考",
        "groups": [
          {
            "group": "用户",
            "pages": [
              "api-reference/user/register",
              "api-reference/user/login",
              "api-reference/user/logout",
              "api-reference/user/update"
            ]
          },
          {
            "group": "资产",
            "pages": [
              "api-reference/asset/transfer"
            ]
          },
          {
            "group": "API Key",
            "pages": [
              "api-reference/apikey/create-apikey",
              "api-reference/apikey/list-apikey",
              "api-reference/apikey/update-apikey",
              "api-reference/apikey/delete-apikey"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "logo": {
    "light": "/public/logo-light.svg",
    "dark": "/public/logo-dark.svg"
  },
  "openapi": "openapi.json",
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/phx-de"
    }
  }
}
